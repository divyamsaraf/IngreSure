# Committed defaults for Docker Compose only.
# Loaded before backend/.env (see repo root docker-compose.yml): values in backend/.env override these.
#
# Ollama on the host machine (Docker Desktop / Linux with host-gateway):
OLLAMA_API_URL=http://host.docker.internal:11434/api/generate

# Do not set REDIS_URL here. When using Compose profile "cache", add to backend/.env:
#   REDIS_URL=redis://redis:6379/0
# so the API uses the resolution cache alongside Celery.
