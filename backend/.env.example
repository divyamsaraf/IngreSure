# IngreSure backend env (copy to .env)

# --- Docker Compose ---
# Compose loads backend/.env.compose first, then this file — your values here override .env.compose.
# For OCI / remote LLM set:
#   OLLAMA_API_URL=http://<private_llm_ip>:11434/api/generate
# With Redis + Celery (compose profile "cache"), add:
#   REDIS_URL=redis://redis:6379/0

# --- Production / security ---
# ENVIRONMENT=production  → hide exception details in 500 responses (generic "Internal server error")
# ENVIRONMENT=production

# CORS: comma-separated allowed origins. If unset, allows all (*) — fine for local dev.
# IMPORTANT: when ENVIRONMENT=production, CORS_ORIGINS MUST be set to a specific,
# non-wildcard origin list — the app refuses to start (RuntimeError) if it is unset
# or "*" while in production (see core/security/cors_guard.py).
# Vercel: include your app URL and custom domain, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,https://yourdomain.com
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# Redact PII (query, user_id, etc.) in log lines when set (e.g. production)
# LOG_REDACT_PII=1

# --- Rate limiting (see backend/core/security/rate_limit.py) ---
# Caller identification precedence: X-API-Key > Authorization Bearer (anon-session) > IP.
# All limits below are optional; defaults shown are used when unset.
# RATE_LIMIT_CHAT_ANON=20/minute        # /chat/grocery, anonymous (IP-keyed) callers
# RATE_LIMIT_CHAT_AUTH=30/minute        # /chat/grocery, authenticated (API key / user token) callers
# RATE_LIMIT_PROFILE_READ=60/minute     # GET /profile/{user_id}
# RATE_LIMIT_PROFILE_WRITE=30/minute    # POST /profile
# RATE_LIMIT_API_V1_DEFAULT=60/minute   # /api/v1/* fallback when no/unknown API key
# RATE_LIMIT_B2B_STARTER=60/minute      # /api/v1/* for API keys tagged "starter" in B2B_API_KEYS
# RATE_LIMIT_B2B_GROWTH=300/minute      # /api/v1/* for API keys tagged "growth" in B2B_API_KEYS
# RATE_LIMIT_B2B_ENTERPRISE=1000/minute # /api/v1/* for API keys tagged "enterprise" in B2B_API_KEYS

# B2B API keys for /api/v1/* and /profile (send as X-API-Key header, or
# Authorization: Bearer <key>): JSON object mapping key -> tenant info.
# org_id namespaces that tenant's /profile storage (core/security/tenancy.py) so
# org A can never read/write org B's data. tier selects the /api/v1/* rate limit
# (RATE_LIMIT_B2B_* above); unrecognized/missing keys fall back to RATE_LIMIT_API_V1_DEFAULT.
# rpm is reserved for future per-key limits (not yet enforced).
# Optional X-User-Id header (or path/body user_id) selects which end-user's profile
# within that org's namespace to read/write.
# B2B_API_KEYS={"sk_live_abc123": {"org_id": "org_acme", "tier": "starter", "rpm": 60}}
#
# Legacy shorthand (tier only, no tenant isolation) is still accepted for rate limiting:
# B2B_API_KEYS={"key_abc123": "starter", "key_def456": "growth", "key_xyz789": "enterprise"}

# --- Chat / API ---
# Max length of chat query (default 8192). Served to frontend via GET /config.
# MAX_CHAT_MESSAGE_LENGTH=8192

# --- LLM / Ollama ---
# Set false to disable all Ollama calls (rules + templates only; no warmup).
# LLM_ENABLED=true
# Local uvicorn (no Docker): use localhost
# OLLAMA_API_URL=http://localhost:11434/api/generate
# Docker Compose: default is in backend/.env.compose (host.docker.internal); override here if needed.
# OLLAMA_MODEL=llama3.2:3b
# LLM_INTENT_TIMEOUT=30
# LLM_RESPONSE_TIMEOUT=30

# --- External APIs ---
# USDA FoodData Central (https://fdc.nal.usda.gov/api-key-signup)
# USDA_FDC_API_KEY=your_key_here
# Open Food Facts (no key needed; set false to disable)
OPEN_FOOD_FACTS_ENABLED=true

# --- Supabase (ingredient knowledge DB, optional users) ---
# SECURITY: SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security and must stay
# backend-only — env var here, never in frontend/ (no NEXT_PUBLIC_ prefix, no
# hardcoding, never committed). `python scripts/check_secrets_hygiene.py` (run
# in CI) fails the build if this pattern ever leaks into frontend/. If a
# service-role key is ever exposed (committed, logged, or pasted into a
# frontend env file), rotate it immediately in the Supabase dashboard —
# treat exposure as compromised, not just "fix and move on".
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Local: supabase status -o json → use API_URL and SERVICE_ROLE_KEY
#   SUPABASE_URL=http://127.0.0.1:54321
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Docker: backend/worker set RUNNING_IN_DOCKER=1 so 127.0.0.1/localhost → host.docker.internal
# Knowledge DB resolution uses Supabase when URL and service role key are set and tables exist.

# Server-issued anonymous identity (docs/auth-and-identity.md). When set, GET /anon-session returns a signed token.
# Frontend sends Authorization: Bearer <token>; backend uses token user_id instead of body user_id.
# ANON_SESSION_SECRET=your_secret_at_least_32_chars

# Optional: demo user password for seed_user.py (local dev only; set securely in production)
# DEMO_USER_PASSWORD=your_secure_password

# --- Optional (Redis cache + Celery; use with: docker compose --profile cache up) ---
# REDIS_URL=redis://redis:6379/0
# Local Redis without Docker network name:
# REDIS_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# BACKEND_URL=http://127.0.0.1:8000  (used by scripts and frontend BFF; frontend sets in its .env)
