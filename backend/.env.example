# IngreSure backend env (copy to .env)

# Use new deterministic compliance engine for /scan and /chat/grocery
USE_NEW_ENGINE=true
# When true, run legacy engine alongside and log diffs (for comparison)
SHADOW_MODE=false

# Optional: USDA FoodData Central API key (https://fdc.nal.usda.gov/api-key-signup)
# USDA_FDC_API_KEY=your_key_here
# Open Food Facts API (no key needed; set false to disable)
OPEN_FOOD_FACTS_ENABLED=true

# Supabase (for RAG, storage, and ingredient knowledge DB)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Local: supabase status -o json → use API_URL and SERVICE_ROLE_KEY
#   SUPABASE_URL=http://127.0.0.1:54321
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Docker: backend/worker set RUNNING_IN_DOCKER=1 so 127.0.0.1/localhost is rewritten to host.docker.internal

# Use Supabase for canonical ingredient resolution and unknown_ingredients (when set and DB has tables)
USE_KNOWLEDGE_DB=true

# Optional: demo user password for seed_user.py (default for local dev only; set in production)
# DEMO_USER_PASSWORD=your_secure_password
